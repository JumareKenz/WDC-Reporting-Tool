{
  "name": "kadwdc-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:native": "cross-env VITE_BUILD_TARGET=native vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build:native && npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:run": "npm run build:native && npx cap sync android && npx cap run android",
    "cap:live": "npx cap run android --livereload --external",
    "android:build": "vite build && npx cap sync && npx cap open android",
    "android:preview": "vite build && npx cap sync && npx cap run android",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "PW_HEADED=1 playwright test"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@tanstack/react-query": "^5.17.0",
    "axios": "^1.6.5",
    "framer-motion": "^12.39.0",
    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.303.0",
    "mirada": "^0.0.15",
    "opencv.js": "^1.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.21.0",
    "recharts": "^2.10.3",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@playwright/test": "^1.58.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "cross-env": "^7.0.3",
    "happy-dom": "^20.5.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.4.33",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.11",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
