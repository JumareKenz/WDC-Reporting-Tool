{
  "appId": "ng.gov.kaduna.wdc.reporting",
  "appName": "Kaduna WDC Reports",
  "webDir": "dist",
  "android": {
    "minSdkVersion": 22,
    "targetSdkVersion": 34,
    "buildToolsVersion": "34.0.0"
  },
  "server": {
    "androidScheme": "https",
    "allowNavigation": []
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#1F4438",
      "showSpinner": false,
      "launchAutoHide": false,
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#1F4438"
    }
  }
}
